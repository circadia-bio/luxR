Package: luxR
Title: Light Exposure and Photic Regularity Analysis for Chronobiology Research
Version: 0.0.0.9000
Authors@R: c(
    person("Lucas", "França",
           email = "lucas.franca@northumbria.ac.uk",
           role = c("aut", "cre"),
           comment = c(ORCID = "0000-0003-0853-1319")),
    person("Mario", "Leocadio-Miguel",
